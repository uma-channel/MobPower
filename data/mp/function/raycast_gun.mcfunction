tellraw @s {text:"攻撃方向を設定しました！攻撃を開始します..."}

execute anchored eyes run summon minecraft:item_display ^ ^ ^0.5 {Tags:["gun"]}
execute anchored eyes run summon minecraft:item_display ^ ^ ^0.5 {Tags:["circle1","gun_circle"]}
execute anchored eyes run summon minecraft:item_display ^ ^ ^0.5 {Tags:["circle2","gun_circle"]}
execute anchored eyes run summon minecraft:item_display ^ ^ ^0.5 {Tags:["circle3","gun_circle"]}

rotate @e[tag=gun,limit=1,sort=nearest] facing entity @s eyes
rotate @e[tag=circle1,limit=1,sort=nearest] facing entity @s eyes
rotate @e[tag=circle2,limit=1,sort=nearest] facing entity @s eyes
rotate @e[tag=circle3,limit=1,sort=nearest] facing entity @s eyes
execute as @e[tag=circle1,limit=1,sort=nearest] at @s run tp @s ^ ^ ^2.5 ~90 ~
execute as @e[tag=circle2,limit=1,sort=nearest] at @s run tp @s ^ ^ ^2.5 ~90 ~
execute as @e[tag=circle3,limit=1,sort=nearest] at @s run tp @s ^ ^ ^2.5 ~90 ~

execute as @e[tag=gun_circle] store result score @s base_yaw run data get entity @s Rotation[0] 1

